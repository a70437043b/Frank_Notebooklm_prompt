    structures: [
        { id: 's1', label: 'SCQA', prompt: '運用「情境-衝突-問題-回答」模式，在開場建立共鳴並引出矛盾，隨後提供精準解決方案，適合用於具備敘事感的商務提案或產品介紹。' },
        { id: 's2', label: '金字塔', prompt: '採取「結論先行」原則，由上而下進行邏輯拆解與證據支撐，確保高階決策者能瞬時掌握重點，適用於嚴謹的專業報告。' },
        { id: 's3', label: 'FAB', prompt: '透過描述產品屬性、轉化競爭優勢並對接用戶最終利益，將技術語言轉譯為感性價值，適合用於行銷文案或業務銷售，強力驅動購買慾望。' },
        { id: 's4', label: 'AIDA', prompt: '遵循注意、興趣、慾望、行動的漏斗路徑，逐步引導受眾情緒並最終觸發轉化，是設計廣告文案或導購頁面的黃金法則，能有效提升點擊與成交。' },
        { id: 's5', label: 'PASTOR', prompt: '從鎖定問題、放大痛點、提供解方到見證成果，最後呼籲行動，以救贖者姿態建立深度信任，適用於高價產品銷售或深度的行銷長信。' },
        { id: 's6', label: '黃金圈', prompt: '從 Why 核心動機出發，延伸至 How 執行方法與 What 最終成果，強調品牌價值與信念，適合用於建立品牌忠誠度或激勵人心的願景演說。' },
        { id: 's7', label: '問題解決', prompt: '採「痛點分析-對策提出-預期效益」三段式編排，針對具體難題提供落地指引，風格務實且具執行力，適用於客戶服務手冊或內部流程優化建議。' },
        { id: 's8', label: '決策樹權衡', prompt: '採分支路徑架構，詳細列出不同決策節點的投入回報比與風險預估，以數據化視角輔助理性權衡，適用於複雜的商業策略評估或投資分析。' },
        { id: 's9', label: '心理誘因', prompt: '結合行為經濟學原理，在內容佈局中置入稀缺性、社會認同與對比效應，微妙引導受眾潛意識決策，適合用於短時促銷活動或高轉化率頁面設計。' },
        { id: 's10', label: '模組系統', prompt: '將核心知識拆解為標準化功能模組，透過組裝式邏輯呈現各組件關聯，提升內容重用性與擴充感，適用於軟體架構說明或大型專案系統規劃。' },
        { id: 's11', label: 'SWOT 戰略分析', prompt: '透過優勢、劣勢、機會與威脅四維度評估，全面剖析企業現狀與外部環境，產出具備競爭力的對策，適用於年度策略規劃或新市場切入點分析。' },
        { id: 's12', label: 'MECE 窮盡分類', prompt: '遵循「相互獨立、完全窮盡」原則，將複雜議題結構化，確保邏輯無漏洞且不重疊，適用於管理顧問的診斷報告或系統化的知識百科整理。' },
        { id: 's13', label: '第一性原理', prompt: '回歸事物最基礎的真理進行推導，剝離類比與過往經驗的束縛，重構核心邏輯以達成顛覆式創新，適用於產品研發或技術突破的底層邏輯論證。' },
        { id: 's14', label: 'PREP 強力溝通', prompt: '採用「點出觀點-給予理由-實證案例-重申立場」的循環，在短時間內建立強大說服力，適合用於即興演講、會議發言或職場高效溝通情境。' },
        { id: 's15', label: '5W1H 全維拆解', prompt: '從人、事、時、地、物、為何及如何七大維度，全方位還原事件真相或任務全貌，確保資訊傳遞零死角，適用於新聞報導、事故調查或專案啟動。' },
        { id: 's16', label: '80/20 價值聚焦', prompt: '識別並聚焦於 20% 的關鍵驅動因素，優化資源配置以極大化產出效益，風格專注且高效，適用於績效考核、時間管理或核心業務優化策略。' },
        { id: 's17', label: 'PESTEL 宏觀分析', prompt: '從政治、經濟、社會、技術、環境及法律六大面向，剖析產業大環境的潛在影響，建立長遠戰略視角，適用於跨國市場調研或宏觀趨勢預測。' },
        { id: 's18', label: 'OKR 目標檢核', prompt: '以具備野心的願景目標為核心，掛鉤具體且可衡量的關鍵結果，強調進度追蹤與靈活修正，適用於團隊敏捷開發、創業增長與個人目標達成管理。' },
        { id: 's19', label: '失敗預判演練', prompt: '假設專案已經失敗，從終點倒推可能的崩潰點與風險成因，並制定預防性防範措施，適用於高風險決策前的極端壓力測試與危機應變規劃。' },
        { id: 's20', label: '關鍵路徑管理', prompt: '識別任務序列中最核心的連續路徑，精確掌控時程進度與資源瓶頸，確保專案如期完工，適用於工程建設、大型活動執行或複雜的產品開發管理。' },
        { id: 's21', label: '需求層次驅動', prompt: '根據馬斯洛需求理論分析受眾內在動機，精準切換不同層次的溝通策略與價值主張，適合用於品牌定位、用戶心理洞察或高深度的內容行銷。' },
        { id: 's22', label: 'PDCA 持續迭代', prompt: '遵循「計畫-執行-查核-行動」循環邏輯，建立自我優化與反饋機制，確保流程不斷進化，適用於品質管理、技術維運或個人習慣的持續改進。' },
        { id: 's23', label: '逆向工程推演', prompt: '從最終理想目標出發，倒推所需的前置條件、資源與必經階段，釐進執行路徑的優先順序，適用於新產品開發、策略破局或職涯發展規劃。' },
        { id: 's24', label: '利益關係人矩陣', prompt: '依據影響力與權力對相關方進行分類，制定差異化的溝通與管理策略，化解阻力並爭取支持，適用於跨部門專案協作或大型社會倡議活動。' },
        { id: 's25', label: '故事弧線邏輯', prompt: '採用「鋪陳-觸發-對抗-高潮-解決」的經典劇作結構，營造情緒張力與沉浸體驗，引發受眾深度共鳴，適用於品牌形象片、微電影或感性專題文案。' }
    ],
    infographics: [
        { id: 'i1', label: '企業美學型', prompt: '運用深藍金漸層色調，配合精確幾何箭頭，在商業提案中展現專業深度與科技質感，大幅提升權威感與品牌信任，讓合作夥伴對實力留下深刻印象。' },
        { id: 'i2', label: '數據視覺型', prompt: '透過多維度數據圖表與透明覆蓋層，將複雜資料轉化為直覺分析，於季度報告中提升專業感與含金量，協助決策者快速掌握市場動態趨勢與機會。' },
        { id: 'i3', label: '極簡觀點型', prompt: '採用極致留白設計，側重單一核心關鍵字與精煉線條，於品牌發表會中建立強大視覺記憶點，引導觀眾進行深度思考並專注於核心品牌精神價值。' },
        { id: 'i4', label: '卡片對比型', prompt: '使用多重矩形卡片佈局呈現並列資訊，在產品功能比較表中清晰呈現各項方案優劣，輔助決策層做出精準判斷並優化產品選購決策流程中的細節。' },
        { id: 'i5', label: '邏輯流程型', prompt: '結合橫向時間軸導向與色彩分區，在專案進度匯報中明確標註執行步驟，強化團隊的工作節奏與任務協作效率，確保專案按計畫時程穩定推進。' },
        { id: 'i6', label: '視覺震撼型', prompt: '以震撼的高畫質全螢幕圖片為基底，搭配高對比金句文案，在演講開場快速凝聚受眾專注力，營造沉浸式氛圍並激發聽眾對於主題的深度共鳴。' },
        { id: 'i7', label: '社群互動型', prompt: '模擬社群媒體氣泡對話感與明快配色，於知識科普貼文中引發受眾情感共鳴，有效增加互動討論度與品牌黏著，建立具備活力的線上社群生態。' },
        { id: 'i8', label: '破除迷思型', prompt: '採用左右強烈對比佈局與醒目錯誤修正標誌，清楚標註誤區與真相，在教育宣導中有效矯正舊觀念，幫助受眾建立正確科學知識與核心理解力。' },
        { id: 'i9', label: '金字塔階層', prompt: '運用階層三角形視覺架構，從基礎層級逐層遞升，在組織架構介紹中展現嚴謹的邏輯關係與職責劃分細節，讓新手也能快速掌握各部門權責關係。' },
        { id: 'i10', label: '韋恩圖交集', prompt: '利用半透明幾何體重疊區域，在市場定位分析中展現不同維度間的關聯性，精準鎖定核心競爭優勢與藍海切入點，為品牌找出獨特的市場立足點。' },
        { id: 'i11', label: '數據儀表板', prompt: '模擬數位監控介面並內嵌趨勢折線圖，於年度業績回顧中展現數據驅動的決策過程，提升分析的深度與科技視覺感，讓數據成為最有力的證明。' },
        { id: 'i12', label: '新聞雜誌型', prompt: '仿效雜誌封面設計巨大標題與兩欄導讀，在深度專題報導中營造權威感，大幅提升長篇內容的高可讀性與美學價值，適合用於品牌文化故事傳遞。' },
        { id: 'i13', label: '路線圖成長', prompt: '運用蜿蜒進步曲線貫穿畫面，在個人職涯規劃中展示成長路徑，具體呈現各階段關鍵目標與成就，增加勵志感染力並勾勒出清晰的未來願景。' },
        { id: 'i14', label: '漫畫格敘事', prompt: '切割為多個漫畫方格並配獨立對話框，在品牌故事傳遞中增加趣味性，透過連貫情節引發受眾共鳴，顯著降低複雜產品資訊的閱讀負擔與阻力。' },
        { id: 'i15', label: '產品目錄型', prompt: '以網格式排列物件圖示並配精簡規格標籤，在電子商務展示頁面中協助客戶快速比較產品，提升轉化率與購買意願，並呈現出專業的產品陣容。' },
        { id: 'i16', label: 'SWOT分析', prompt: '採取標準四象限佈局與平衡配色，在企業戰略評估中清晰界定優勢、劣勢、機會與威脅，提供客觀且具落地性的戰略決策依據與轉型發展建議。' },
