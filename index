<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>「Frank_notebooklm」提示詞資料庫 V2.2 (影音強化版)</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<style>
    .scrollbar-thin::-webkit-scrollbar { width: 6px; height: 6px; }
    .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
    .scrollbar-thin::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    .dark-scrollbar::-webkit-scrollbar-thumb { background: #334155; }
    #resizer:hover { background-color: #818cf8; }

    .selection-btn {
        font-weight: 800 !important; 
        color: #1e293b !important;
        transition: all 0.2s ease;
        word-break: break-word;hyphens: auto;
        line-height: 1.2;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .selection-btn.active {
        border-color: #4f46e5 !important;
        background-color: #f5f3ff !important;
        color: #4338ca !important;
        font-weight: 900 !important;
        box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.06);
        transform: translateY(1px);
    }

    .dropdown-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out;
        position: relative;
        z-index: 10;
    }

    .dropdown-content.show {
        max-height: 2500px; 
        transition: max-height 0.6s ease-in;
    }

    .chevron-icon {
        transition: transform 0.3s ease;
    }

    .rotate-180 {
        transform: rotate(180deg);
    }

    .label-clr-0 { background-color: #eef2ff; color: #4338ca !important; border-left: 4px solid #4338ca; }
    .label-clr-1 { background-color: #ecfdf5; color: #059669 !important; border-left: 4px solid #059669; }
    .label-clr-2 { background-color: #fffbeb; color: #d97706 !important; border-left: 4px solid #d97706; }
    .label-clr-3 { background-color: #fff1f2; color: #e11d48 !important; border-left: 4px solid #e11d48; }
    .label-clr-4 { background-color: #faf5ff; color: #9333ea !important; border-left: 4px solid #9333ea; }

    .btn-clr-0 { background-color: #f8fafc; }
    .btn-clr-1 { background-color: #f0f9ff; }
    .btn-clr-2 { background-color: #f0fdf4; }
    .btn-clr-3 { background-color: #fefce8; }
</style>
</head>
<body class="h-screen bg-slate-100 flex flex-col font-sans text-slate-900 overflow-hidden">

<header class="shrink-0 p-3 border-b border-slate-200 bg-white z-20 shadow-sm">
    <div class="max-w-full mx-auto flex items-center justify-between">
        <h1 class="text-lg font-black text-slate-800 flex items-center gap-2">
            <span class="bg-indigo-600 text-white px-1.5 py-0.5 rounded text-xs tracking-tighter shadow-sm">P.L.</span>
            「Frank_notebooklm」提示詞資料庫<span class="text-[10px] text-slate-400 font-normal uppercase">V2.2</span>
        </h1>
        <div class="flex items-center gap-2">
            <button id="reset-all-btn" class="text-[10px] font-bold text-red-500 hover:text-red-700 border border-red-100 bg-red-50 px-3 py-1 rounded transition-all active:scale-95 uppercase tracking-tighter flex items-center gap-1">
                <i data-lucide="x-circle" class="w-3 h-3"></i> 全部清除
            </button>
        </div>
    </div>
</header>

<main class="flex-grow flex flex-nowrap overflow-hidden p-3 gap-0" id="container">
    <div id="left-panel" class="h-full flex flex-col shrink-0 overflow-hidden border border-slate-200 rounded-l-lg bg-white shadow-sm" style="flex-basis: 60%;">
        <div class="flex-grow overflow-y-auto overflow-x-hidden p-4 scrollbar-thin">
            <div class="w-full" id="config-sections">
                <div class="mb-4 p-3 label-clr-0 rounded-r-lg border border-indigo-100">
                    <h3 class="text-[10px] font-black uppercase tracking-tight mb-2 flex items-center gap-2">
                        <i data-lucide="sparkles" class="w-3.5 h-3.5"></i> AI投影片風格分析
                    </h3>
                    <div class="flex items-center gap-3">
                        <label class="flex-1 cursor-pointer flex items-center justify-center gap-2 border-2 border-dashed border-indigo-300 bg-white rounded-md p-2 hover:border-indigo-500 transition-all">
                            <input type="file" id="file-input" class="hidden" accept="image/*,.pdf">
                            <div id="file-display" class="flex items-center gap-2 text-indigo-500">
                                <i data-lucide="upload" class="w-4 h-4"></i>
                                <span class="text-[10px] font-bold">上傳 PDF 或圖片檔案</span>
                            </div>
                        </label>
                        <div class="flex flex-col gap-1 w-32 shrink-0">
                            <button id="analyze-detailed" class="px-3 py-1.5 rounded-md text-[10px] font-bold bg-white/50 border border-indigo-200 text-slate-400" disabled>深度分析風格</button>
                            <button id="analyze-concise" class="px-3 py-1.5 rounded-md text-[10px] font-bold bg-white/50 border border-indigo-200 text-slate-400" disabled>精簡分析核心</button>
                        </div>
                    </div>
                </div>

                <div class="mb-3 p-3 label-clr-1 rounded-r-lg border border-emerald-100">
                    <h3 class="text-[10px] font-black uppercase mb-1 leading-none">0. 封面標題</h3>
                    <input type="text" id="title-input" placeholder="輸入主題..." class="w-full px-2 py-1.5 rounded border border-emerald-200 bg-white text-[10px] font-bold outline-none shadow-inner focus:ring-1 focus:ring-emerald-400 transition-all">
                </div>

                <div class="mb-4">
                    <button id="clear-selections-btn" class="w-full text-[10px] font-bold bg-slate-800 hover:bg-black text-white py-2 rounded shadow-sm uppercase tracking-wider transition-colors">一鍵取消所有選取</button>
                </div>

                <div id="selection-groups-container" class="space-y-2"></div>

                <div class="mt-6 pt-4 border-t-2 border-slate-100">
                    <h3 class="text-[11px] font-black text-purple-700 uppercase mb-2 italic flex items-center gap-1">
                        <i data-lucide="edit-3" class="w-3 h-3"></i> 12. 其他自訂備註 (AI 分析結果填入處)
                    </h3>
                    <textarea id="custom-notes-input" placeholder="在此輸入額外細節要求..." class="w-full h-32 p-3 rounded-lg border-2 border-purple-500 bg-purple-50/30 text-[10px] outline-none resize-none shadow-md shadow-purple-100 focus:bg-white focus:ring-2 focus:ring-purple-600 transition-all font-bold text-slate-800 placeholder:text-purple-300"></textarea>
                </div>
            </div>
        </div>
    </div>

    <div id="resizer" class="w-1.5 h-full cursor-col-resize transition-colors flex items-center justify-center bg-slate-200 group">
        <div class="w-[1px] h-16 bg-slate-400 group-hover:bg-white rounded-full"></div>
    </div>

    <div id="right-panel" class="h-full flex-1 min-w-0 flex flex-col border border-slate-800 rounded-r-lg shadow-xl bg-slate-900">
        <div class="px-3 py-1.5 bg-slate-800 flex justify-between items-center border-b border-slate-700 shrink-0">
            <span class="text-[10px] text-slate-400 font-mono tracking-widest uppercase">Prompt Output</span>
            <button id="copy-btn" class="text-[10px] font-bold bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-1 rounded transition-all active:scale-95 shadow-md uppercase">Copy</button>
        </div>
        <div class="p-4 overflow-y-auto flex-grow font-mono text-[11px] text-indigo-100/90 leading-tight scrollbar-thin dark-scrollbar">
            <pre id="prompt-output" class="whitespace-pre-wrap"></pre>
        </div>
    </div>
</main>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
import { getFirestore, doc, setDoc, getDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

const INITIAL_CONFIG = {
    types: [
        { id: 't1', label: '流量企劃', prompt: '你是一位百萬影音大師。請規劃一份針對熱門趨勢、具備高留存率與爆發力的影片策略，明確標註吸引點。' },
        { id: 't2', label: '簡報製作', prompt: '作為頂級顧問，設計一份邏輯嚴密、結構清晰的簡報大綱。要求風格洗鍊，能滿足決策展示需求。' },
        { id: 't3', label: '影音腳本', prompt: '以資深編劇身份，撰寫節奏感強、運鏡描述明確的影音腳本，適用各類創作，讓畫面感躍然紙上。' },
        { id: 't4', label: '商業／行銷企劃', prompt: '作為行銷經理，撰寫一份具可行性與市場洞察的企劃。包含目標設定與執行細節，適用於專案提案。' },
        { id: 't5', label: '教學簡報', prompt: '你是教學專家。設計一套循序漸進、針對學習目標的教學大綱。風格親切易懂，協助受眾高效吸收。' },
        { id: 't6', label: '社群貼文', prompt: '擔任社群操盤手，規劃具備高互動潛力、風格獨特的貼文。針對平台語境，設計吸引點與行動指令。' },
        { id: 't7', label: '產品文案', prompt: '你是頂尖文案人。設計一份強調賣點轉化、解決痛點的文案。風格需具說服力，適用於商務網頁。' },
        { id: 't8', label: '懶人包', prompt: '以設計專家視角，規劃資訊高度濃縮、視覺引導強烈的懶人包架構。讓複雜主題能被受眾一眼看懂。' },
        { id: 't9', label: '投資人簡報', prompt: '你是融資顧問。針對投資人需求，聚焦市場規模與商業壁壘規劃簡報。風格穩重權威，突顯競爭力。' },
        { id: 't10', label: '報告型簡報', prompt: '擔任商業分析師，規劃一份數據導向、結論明確的報告型簡報。結構嚴謹，適用於企業內部季總結。' },
        { id: 't11', label: '故事敘述型', prompt: '透過鮮活角色與情節發展呈現內容，強調情緒張力與衝突。適用於品牌感性行銷，引發受眾深度共鳴。' },
        { id: 't12', label: '數據分析型', prompt: '結合具體數據與圖表進行深入分析，強調趨勢洞察與客觀結論。風格嚴謹理智，適用於專業研究報告。' },
        { id: 't13', label: '品牌故事型', prompt: '詳細描述品牌起源與價值理念，建立情感連結與信任。風格溫潤有度，適用於官網或形象宣傳。' },
        { id: 't14', label: '短影音腳本型', prompt: '設計節奏快速、具視覺衝擊的短影音腳本。包含黃金開場與結尾行動導引，適用於社群媒體爆款傳播。' },
        { id: 't15', label: '長影片腳本型', prompt: '規劃結構完整的影片架構，包含詳細的情緒轉折與敘事層次。風格宏大深遠，適用於影音平台深度專題。' },
        { id: 't16', label: '訪談對話型', prompt: '以一問一答方式呈現內容，模擬真實的訪談情境與對話節奏。風格自然流暢，適用於職涯分享或專家座談。' },
        { id: 't17', label: '專欄評論型', prompt: '以專家角度對特定議題進行深度評論，提出獨到觀點與犀利分析。風格權威大氣，適用於各大媒體專欄。' },
        { id: 't18', label: '日記反思型', prompt: '採用第一人稱記錄心路歷程，強調真實感受與內在成長。風格真摯動人，適用於個人品牌建立或札記。' },
        { id: 't19', label: '雜誌報導型', prompt: '模仿雜誌特稿風格撰寫，兼具深度探索與優質可讀性。排版邏輯清晰，適用於產業人物專訪或風格報導。' },
        { id: 't20', label: '創意發想型', prompt: '提出多元且突破框架的創新點子，強調靈感的發散與關聯性。風格跳脫常規，適用於腦力激盪與新提案。' },
        { id: 't21', label: '問題解決型', prompt: '針對特定痛點提出具體解決方案，包含執行步驟與實務建議。風格務實直接，適用於客戶服務或指南。' },
        { id: 't22', label: '流程規劃型', prompt: '清楚列出所有執行流程與節點步驟，確保邏輯連貫。風格條理分明，適用於專案管理與作業程序標準化。' },
        { id: 't23', label: '比較分析型', prompt: '對多種選項進行全方位優缺點比較，幫助做出理性決策。風格中立客觀，適用於產品選型或策略評估。' },
        { id: 't24', label: '靈感金句型', prompt: '生成簡短有力、具備辨識度的核心句子。風格精煉且富有哲理，適用於社群分享、海報設計或標語口號。' },
        { id: 't25', label: '插畫描述型', prompt: '詳細描述畫面構圖、色彩氛圍與藝術風格，提供精確指引。適用於 AI 圖像生成或插畫創作的創意描述。' },
        { id: 't26', label: '企劃提案型', prompt: '撰寫完整的企劃提案內容，涵蓋目標設定、核心策略與執行時程。風格專業正式，適用於對外合作投標。' },
        { id: 't27', label: '知識整理型', prompt: '將龐雜資訊整理成條理化知識體系，方便記憶與理解。風格清晰架構化，適用於學習筆記或企業知識庫。' },
        { id: 't28', label: '案例研究型', prompt: '分析實際成功案例內容，整理關鍵因素與經驗啟發。風格深入淺出，適用於商學院教材或產業競爭分析。' },
        { id: 't29', label: '趨勢觀察型', prompt: '分析當前產業趨勢變化，提出未來的發展方向與前瞻洞察。風格具遠見性，適用於年度展望或趨勢專題。' },
        { id: 't30', label: '情境模擬型', prompt: '設定具體的生活或工作情境進行推演，增加真實代入感。風格寫實靈活，適用於員工培訓或產品演示。' },
        { id: 't31', label: '反轉觀點型', prompt: '從非傳統角度切入既有主題，提出顛覆性的見解與思考。風格新穎獨特，適用於觀點碰撞與爆款文案。' },
        { id: 't32', label: '角色扮演型', prompt: '以特定角色的獨特視角進行創作，強化口吻個性。風格鮮明生動，適用於沉浸式文案、遊戲劇本或小說。' },
        { id: 't33', label: '戰略白皮書型', prompt: '以權威視角剖析宏觀趨勢，提供落實建議。風格正式、嚴謹且權威，適用於政府政策或企業戰略白皮書。' },
        { id: 't34', label: '思維願景型', prompt: '描繪未來的理想藍圖與價值體系，結合感性與理性的號召。風格鼓舞人心，適用於演講或願景發布。' },
        { id: 't35', label: '實戰工具箱型', prompt: '將理論轉化為工具模板與操作清單，提供執行指南。風格實用精準，適用於工作坊或奈米級實踐教程。' }
    ],
    roles: [
        { id: 'edit', label: '剪輯大師', prompt: '精通視聽語言與調色的後期專家，規劃流暢且具節奏感的影片剪輯與畫面層次。' },
        { id: 'short', label: '短影音操盤', prompt: '擅長社群演算法與爆款內容，規劃高效的流量策略，精準提升影片的社群曝光度。' },
        { id: 'marketer', label: '行銷策略師', prompt: '敏銳捕捉受眾痛點，規劃具說服力的行銷方案，在競爭市場中精準提升產品轉化率。' },
        { id: 'vmedia5', label: '封面點擊大師', prompt: '視覺心理專家，設計重點標題突出且具吸引力的封面，極大化內容的點擊與轉化。' },
        { id: 'storyteller', label: '說故事高手', prompt: '擅長將複雜概念轉化為動人敘事，運用感性風格與情節，為品牌建立深層情感連結。' },
        { id: 'analyst', label: '數據分析師', prompt: '嚴謹的數據大師，從混亂資料中洞察產業趨勢，為商業決策提供精準客觀的專業報告。' },
        { id: 'youtuber', label: '內容創作者', prompt: '知名影音創作者，製作具備高互動潛力的創意影音，規劃頻道的長期內容經營藍圖。' },
        { id: 'vmedia7', label: '電影感調色師', prompt: '色彩藝術家，建立獨特顏色風格，賦予影視畫面具備大銀幕質感的視覺情緒色彩。' },
        { id: 'designer', label: '設計師', prompt: '精通資訊圖表與視覺傳達，以專業美學風格美化內容，提升整體內容呈現的專業感。' },
        { id: ' expert', label: '領域專家', prompt: '具備多年實戰經驗，以產業權威角度剖析市場動態，為特定領域提供深度的行動指引。' },
        { id: 'script', label: '編劇總監', prompt: '擅長三幕劇結構，設計具備衝突張力與金句的劇本，適用於各類專業影音創作情境。' },
        { id: 'teacher', label: '科普老師', prompt: '科普教學大師，用親切易懂語言拆解深奧知識，為零基礎受眾規劃循序漸進的課程。' },
