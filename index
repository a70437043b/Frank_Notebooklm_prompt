        { id: 'g-layer', label: '幾何疊加', prompt: '疊加半透明幾何圖案層次，在品牌形象設計中增加現代美學深度，強化整體圖形結構感. ' },
        { id: 'scan', label: '數位掃描', prompt: '覆蓋極細數位掃描線特效，於資安防禦技術說明中模擬電腦監控介面，營造精密技術氣氛. ' },
        { id: 'center', label: '中心對焦', prompt: '採取中心對焦輻射狀版型設計，在單一主打產品促銷圖中將視覺重心鎖定，強化主體感. ' },
        { id: 'glass-c', label: '磨砂容器', prompt: '採用半透明磨砂玻璃容器承載文字，在 App 介面設計中提升細緻質感，營造懸浮美感. ' },
        { id: '3sec', label: '3秒注意力', prompt: '簡化訊息確保在 3 秒內抓住觀眾注意，於短影音開場畫面中快速傳達重點，防止受眾滑過. ' },
        { id: 'split', label: '圖文分離', prompt: '嚴格執行文字與圖像完全分離設計，在複雜技術說明圖中確保閱讀無礙，提升資訊吸收. ' },
        { id: 'light', label: '光影層次', prompt: '透過高品質模擬光影投射層次感，在建築室內渲染圖中營造真實氛圍，增加畫面寫實深度. ' },
        { id: '8k', label: '超高畫質', prompt: '追求細節達到 8K 解析度極致渲染，在高端影視特效設計中展現細微紋理，滿足視覺品質. ' },
        { id: 'new-hook', label: '吸引 Hook', prompt: '開場必須包含一個具備衝擊力的視覺亮點，於廣告短片中即刻建立興趣，降低流失率. ' },
        { id: 'new-quote', label: '金句提煉', prompt: '提煉出具備高度傳播價值的金句短句，於社群媒體經營中建立品牌標籤，增加轉發價值. ' },
        { id: 'new-analogy', label: '生活類比', prompt: '使用生活化類比轉化抽象概念，在深奧技術課程中引導學員建立聯想，協助其快速理解. ' },
        { id: 'new-data', label: '數據支撐', prompt: '預留精確數據展示區塊，於商業談判簡報中增強論據的科學客觀性，全面提升論述說服力. ' },
        { id: 'new-visual', label: '視覺建議', prompt: '針對內容性質標註最佳視覺呈現建議，在跨部門協作中提供統一設計標準，減少溝通成本. ' },
        { id: 'new-cta', label: '行動 CTA', prompt: '結尾處配置具備明確引導的行動呼籲指令，於軟體試用頁面中指示操作路徑，增加點擊量. ' },
        { id: 'new-fubai', label: '歷史伏筆', prompt: '巧妙埋下劇情伏筆並在後文形成回響，在長篇故事腳本中維持懸念感，提升讀者閱讀意願. ' },
        { id: 'n32', label: '符號視覺化', prompt: '關鍵資訊旁置入精確表情符號視覺化，在新手指南中強化直覺理解度，讓內容更加鮮活有趣. ' },
        { id: 'n33', label: '關鍵字加粗', prompt: '全文重要名詞一律採用加粗字體處理，於長篇專業報導中實現一眼抓重點，優化導讀體驗感. ' },
        { id: 'n34', label: '蘇格拉底提問', prompt: '在段落間嵌入引發思考的蘇格拉底提問，於個人成長課程中引導受眾主動自省，內化學習知識. ' },
        { id: 'n35', label: '風險預警標籤', prompt: '使用顯眼警告標誌標註常見執行誤區，在軟體操作手冊中提醒核心風險，減少用戶操作失誤. ' },
        { id: 'n36', label: '奈米級拆解', prompt: '將複雜步驟拆解至奈米級最小執行單位，在 DIY 組裝教學中確保零基礎學員也能依序實踐. ' },
        { id: 'n37', label: '跨領域類比', prompt: '借用其他行業邏輯進行跨領域類比解釋，在跨國企業內訓中激發受眾多元思考，打破慣性思維. ' },
        { id: 'n38', label: '情感弧線設計', prompt: '版面佈局引導情緒由痛點焦慮轉向釋然，於心理輔導頁面中設計情感弧線，達成深度心靈共鳴. ' },
        { id: 'n39', label: '交叉驗證檢查', prompt: '引用至少兩個權威來源進行交叉驗證，在深度市場分析報告中建立客觀真實性，強化內容權威. ' },
        { id: 'n40', label: '文化在地化', prompt: '針對特定區域受眾進行文化在地化調整，於國際品牌廣告中替換當地用語，建立親切溝通連結. ' },
        { id: 'n41', label: '強力動詞驅動', prompt: '標題與指令一律使用強力主動動詞開頭，於業務啟動大會中營造充沛能量感，帶動團隊行動力. ' },
        { id: 'n42', label: '沉浸式五感', prompt: '在文字描述中加入視覺與聽覺暗示，於精品餐飲介紹中營造沉浸式五感，誘發受眾感官慾望. ' },
        { id: 'n43', label: '結論先行結構', prompt: '頁面最頂端直接輸出核心最終結論，於高效商務匯報中節省主管決策時間，後續再展示論證. ' },
        { id: 'n44', label: '互動回饋迴路', prompt: '預留掃碼測驗等讀者互動回饋建議，在知識型內容末尾收集用戶反饋，建立雙向社群互動鏈. ' },
        { id: 'n45', label: '原始資料引用', prompt: '在註腳處明確標註所有數據原始來源出處，於學術性研究報告中展現嚴謹度，確保內容誠信. ' },
        { id: 'n46', label: '核心痛點鎖定', prompt: '開篇精準鎖定受眾最迫切的痛點困擾，於產品推廣文案中建立高度相關性，快速吸引目標客群. ' },
        { id: 'n47', label: '數位足跡追蹤', prompt: '在內容中嵌入特定追蹤標籤語句，於數位行銷活動中分析受眾偏好行為，作為後續優化依據. ' },
        { id: 'n48', label: '解決方案評級', prompt: '對多個路徑進行投入回報比的星等評分，在策略選型報告中清晰展示優劣，輔助理性決策. ' },
        { id: 'n49', label: '視覺隱喻對比', prompt: '利用冰山或種子等視覺隱喻進行對比，在企業品牌願景傳遞中具象化核心價值，提升認同深度. ' },
        { id: 'n50', label: '詞彙難易控制', prompt: '依據設定受眾層級嚴格控制術語難度，於科普類文章中維持易讀性，確保資訊傳遞無門檻. ' },
        { id: 'n51', label: '懸念鋪陳設計', prompt: '在章節末尾留下不完整的關鍵線索，於連載小說或影集腳本中設計懸念，引導受眾持續點閱. ' },
        { id: 'n52', label: '格式一致性檢查', prompt: '確保所有層級標題與間距遵循統一規範，於政府公文或正式報告中展現極致專業與嚴整美學. ' },
        { id: 'n53', label: '專家視角修正', prompt: '在總結處以專家點評形式補充獨到洞察，於產業白皮書中提供內行觀點，大幅提升內容價值. ' },
        { id: 'n54', label: '數據視覺化標註', prompt: '為所有數字內容標註建議使用的圖表類型，在數據視覺化專案中引導設計，確保呈現精確. ' },
        { id: 'n55', label: '轉折點強化', prompt: '在內容邏輯發生改變時使用醒目轉場符號，於演講投影片中引導聽眾節奏，避免注意力渙散. ' },
        { id: 'n56', label: '失敗案例分析', prompt: '加入具體失敗案例清單明確避雷重點，於創業培訓教材中指出潛在風險點，協助受眾降低成本. ' },
        { id: 'n57', label: '自問自答 FAQ', prompt: '預判受眾疑惑並以自問自答形式直接掃除障礙，在系統導覽中快速解答問題，提升用戶滿意度. ' },
        { id: 'n58', label: '多維度矩陣圖', prompt: '建議將複雜資訊轉化為多維度比較矩陣，在產品軟體選型指南中提供視覺參照，輔助高效對比. ' },
        { id: 'n59', label: '心理偏誤利用', prompt: '結合錨定效應等心理偏誤設計文案誘因，於節慶促銷活動中增加吸引力，有效帶動用戶消費. ' },
        { id: 'n60', label: '終極行動清單', prompt: '文末彙整不超過三項的具體終極行動清單，在課程結尾引導學員立即執行，將知識轉化為成果. ' }
    ]
};

const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';

let user = null;
let title = '';
let customNotes = '';
let selections = { roles: [], infographic: null, type: null, structure: null, format: null, wordCount: null, visual_style: null, tone: null, audience: null, color: null, notes: [] };
let openGroups = new Set();

const selectionGroupsContainer = document.getElementById('selection-groups-container');
const titleInput = document.getElementById('title-input');
const customNotesInput = document.getElementById('custom-notes-input');
const promptOutput = document.getElementById('prompt-output');
const copyBtn = document.getElementById('copy-btn');

const buildPrompt = () => {
    let p = "";
    const indent = "　　";
    if (title.trim()) p += `# 主題: "${title.trim()}"\n`;
    if (selections.type) p += `\n# 內容類型\n${indent}${selections.type.label}: ${selections.type.prompt}\n`;
    if (selections.roles.length > 0) {
        p += `\n# 角色設定\n`;
        selections.roles.forEach(r => { p += `${indent}${r.label}- ${r.prompt}\n`; });
    }
    if (selections.structure) p += `\n# 邏輯架構\n${indent}${selections.structure.label}: ${selections.structure.prompt}\n`;
    if (selections.infographic) p += `\n# 懶人包策略\n${indent}${selections.infographic.label}: ${selections.infographic.prompt}\n`;
    if (selections.visual_style) p += `\n# 視覺風格\n${indent}${selections.visual_style.label}: ${selections.visual_style.prompt}\n`;
    if (selections.color) p += `\n# 配色美學\n${indent}${selections.color.label}: ${selections.color.prompt}\n`;
    if (selections.tone) p += `\n# 語氣\n${indent}${selections.tone.label}: ${selections.tone.prompt}\n`;
    if (selections.audience) p += `\n# 目標受眾\n${indent}${selections.audience.label}: ${selections.audience.prompt}\n`;
    if (selections.format) p += `\n# 輸出格式\n${indent}${selections.format.label}: ${selections.format.prompt}\n`;
    if (selections.wordCount) p += `\n# 文字數量限制\n${indent}${selections.wordCount.label}: ${selections.wordCount.prompt}\n`;
    if (customNotes.trim()) p += `\n# 額外自訂要求\n${customNotes.trim()}\n`;
    if (selections.notes.length > 0) {
        p += `\n# 奈米級執行清單\n`;
        selections.notes.forEach(n => { p += `${indent}${n.label}- ${n.prompt}\n`; });
    }
    promptOutput.textContent = p.trim();
};

const renderSelections = () => {
    selectionGroupsContainer.innerHTML = '';
    const groups = [
        { label: "1. 懶人包 (50)", key: "infographics" },
        { label: "2. 內容類型 (35)", key: "types" }, 
        { label: "3. 角色 (50) <span class='text-indigo-500'>✦影音強化</span>", key: "roles", isMulti: true },
        { label: "4. 邏輯架構 (25)", key: "structures" }, 
        { label: "5. 風格 (50)", key: "visual_styles" },
        { label: "6. 語氣 (40)", key: "tones" }, 
        { label: "7. 受眾 (40)", key: "audiences" }, 
        { label: "8. 限定輸出格式 (20)", key: "formats" }, 
        { label: "9. 文字數量限制 (15)", key: "wordCounts" },
        { label: "10. 配色 (40)", key: "colors", isColor: true },
        { label: "11. 備註 (60)", key: "notes", isMulti: true }
    ];

    groups.forEach((group, index) => {
        const groupWrapper = document.createElement('div');
        groupWrapper.className = 'mb-1 border border-slate-100 rounded-md overflow-hidden bg-white';
        const colorClass = `label-clr-${(index + 2) % 5}`;
        const header = document.createElement('button');
        header.className = `w-full flex items-center justify-between p-2 text-[10px] font-black uppercase tracking-tight ${colorClass} transition-all hover:brightness-95`;
        const isOpened = openGroups.has(group.key);
        header.innerHTML = `<span>${group.label} ${group.isMulti ? '<span class="ml-1 opacity-60">(複選)</span>' : ''}</span><i data-lucide="chevron-down" class="w-3 h-3 chevron-icon ${isOpened ? 'rotate-180' : ''}"></i>`;

        const content = document.createElement('div');
        content.className = `dropdown-content z-50 ${isOpened ? 'show' : ''}`;

        const grid = document.createElement('div');
        grid.className = 'grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-5 gap-1 p-1 bg-white relative';

        INITIAL_CONFIG[group.key].forEach((opt, btnIdx) => {
            const btn = document.createElement('button');
            const isActive = group.isMulti ? (selections[group.key] || []).some(n => n.id === opt.id) : (selections[group.key.replace(/s$/, '')] || {}).id === opt.id;
            const btnColorClass = `btn-clr-${btnIdx % 4}`;
            
            btn.className = `selection-btn mx-auto w-[92%] rounded border border-slate-200 text-[11px] p-[0.2rem] break-words whitespace-normal transition-all ${isActive ? 'active' : btnColorClass + ' hover:border-slate-400'}`;
            btn.innerHTML = `<span class="w-full text-center leading-tight">${opt.label}</span>`;
            
            if (group.isColor && opt.swatches) {
                const sw = document.createElement('div');
                sw.className = 'flex gap-0.5 justify-center mt-0.5 w-full';
                opt.swatches.forEach(c => { 
                    const d = document.createElement('div'); 
                    d.className = 'w-1.5 h-1 border border-black/5 rounded-full'; 
                    d.style.backgroundColor = c; 
                    sw.appendChild(d);
                });
                btn.appendChild(sw);
            }

            btn.onclick = (e) => {
                e.stopPropagation();
                if (group.isMulti) {
                    if (!selections[group.key]) selections[group.key] = [];
                    const idx = selections[group.key].findIndex(n => n.id === opt.id);
                    if (idx > -1) selections[group.key].splice(idx, 1); else selections[group.key].push(opt);
                } else {
                    const key = group.key.replace(/s$/, '');
                    selections[key] = selections[key]?.id === opt.id ? null : opt;
                }
                renderSelections(); buildPrompt(); saveToFirebase();
            };
            grid.appendChild(btn);
        });
        
        header.onclick = () => {
            if (openGroups.has(group.key)) openGroups.delete(group.key); else openGroups.add(group.key);
            renderSelections();
        };
        content.appendChild(grid);
        groupWrapper.appendChild(header);
        groupWrapper.appendChild(content);
        selectionGroupsContainer.appendChild(groupWrapper);
    });
    lucide.createIcons();
};

const saveToFirebase = async () => {
    if (!user) return;
    const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'config');
    await setDoc(docRef, { selections, title, customNotes }, { merge: true });
};

titleInput.oninput = (e) => { title = e.target.value; buildPrompt(); saveToFirebase(); };
customNotesInput.oninput = (e) => { customNotes = e.target.value; buildPrompt(); saveToFirebase(); };

copyBtn.onclick = () => {
    const text = promptOutput.textContent;
    if (!text) return;
    const textArea = document.createElement("textarea");
    textArea.value = text;
    textArea.style.position = "fixed";
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();
    try { 
        document.execCommand('copy'); 
        copyBtn.innerText = 'COPIED'; 
        copyBtn.classList.replace('bg-indigo-600', 'bg-green-600');
        setTimeout(() => { 
            copyBtn.innerText = 'COPY'; 
            copyBtn.classList.replace('bg-green-600', 'bg-indigo-600'); 
        }, 2000); 
    } catch (err) { console.error('複製失敗', err); }
    document.body.removeChild(textArea);
};

document.getElementById('reset-all-btn').onclick = () => { if(confirm('確定要全部清除嗎？這會重新整理頁面。')) location.reload(); };
document.getElementById('clear-selections-btn').onclick = () => {
    selections = { roles: [], infographic: null, type: null, structure: null, format: null, wordCount: null, visual_style: null, tone: null, audience: null, color: null, notes: [] };
    renderSelections(); buildPrompt(); saveToFirebase();
};

const init = async () => {
    await signInAnonymously(auth);
    onAuthStateChanged(auth, async (u) => {
        user = u; if (!user) return;
        const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'settings', 'config');
        const snap = await getDoc(docRef);
        if (snap.exists()) {
            const data = snap.data();
            if (data.selections) selections = data.selections;
            if (data.title) { title = data.title; titleInput.value = title; }
            if (data.customNotes) { customNotes = data.customNotes; customNotesInput.value = customNotes; }
        }
        renderSelections(); buildPrompt();
    });
};
init();

const resizer = document.getElementById('resizer');
const leftPanel = document.getElementById('left-panel');
let isResizing = false;
resizer.onmousedown = () => { isResizing = true; document.body.style.cursor = 'col-resize'; };
document.onmousemove = (e) => { if (!isResizing) return; let newWidth = (e.clientX / window.innerWidth) * 100; if (newWidth >= 20 && newWidth <= 85) leftPanel.style.flexBasis = `${newWidth}%`; };
document.onmouseup = () => { isResizing = false; document.body.style.cursor = 'default'; };
</script>
</body>
</html>
